# Copy to .env.local and fill in from Supabase → Project Settings → API.
# These are client-side public keys (safe to expose); this app has no login,
# so anyone with the deployed URL can read/write the golf_* tables.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# PIN for the "Clear all data" action (server-only). Leave APP_PASSCODE blank to
# skip the check. APP_RECOVERY_CODE reveals the PIN via "Forgot PIN?" in Settings.
APP_PASSCODE=
APP_RECOVERY_CODE=
